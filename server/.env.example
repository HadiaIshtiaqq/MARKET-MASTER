# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgresql://marketmaster:password@localhost:5432/marketmaster_ai
DB_HOST=localhost
DB_PORT=5432
DB_NAME=marketmaster_ai
DB_USER=marketmaster
DB_PASSWORD=your_secure_password
DB_SSL=false

# ============================================
# REDIS CONFIGURATION (for job queues)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=wFn+VZgv8aTbWq8iWjfWMhnn+0GVzPFHkYoiX+XEN/U=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=wFn+VZgv8aTbWq8iWjfWMhnn+0GVzPFHkYoiX+XEN/U=
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# IBM WATSONX AI — PRIMARY AI PROVIDER
# ============================================
# Get these from IBM Cloud: https://cloud.ibm.com/catalog/services/watson-machine-learning
# 1. Create an IBM Cloud account
# 2. Provision Watson Machine Learning service
# 3. Create a WatsonX project at https://dataplatform.cloud.ibm.com
# 4. Copy your API key and Project ID below

# IBM Cloud API Key (for IAM token generation)
WATSONX_API_KEY=your_ibm_cloud_api_key_here

# WatsonX.ai Project ID (from https://dataplatform.cloud.ibm.com)
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# WatsonX endpoint URL (default: us-south)
# Options: https://us-south.ml.cloud.ibm.com | https://eu-de.ml.cloud.ibm.com | https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# IBM Granite Models used by MarketMaster AI:
# - ibm/granite-3-8b-instruct      (text generation, NL2SQL, agent reasoning)
# - ibm/granite-3-2-8b-vision-instruct  (Vision-to-Code, document OCR)

# ============================================
# SOCIAL MEDIA API CREDENTIALS
# ============================================

# Instagram Graph API
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret
INSTAGRAM_REDIRECT_URI=http://localhost:3001/api/social-media/callback/instagram

# Facebook Graph API
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_REDIRECT_URI=http://localhost:3001/api/social-media/callback/facebook

# Twitter/X API v2
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret
TWITTER_REDIRECT_URI=http://localhost:3001/api/social-media/callback/twitter

# LinkedIn API
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:3001/api/social-media/callback/linkedin

# TikTok API (requires approval)
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:3001/api/social-media/callback/tiktok

# ============================================
# N8N WORKFLOW INTEGRATION
# ============================================
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_API_KEY=your_n8n_api_key
N8N_BASE_URL=http://localhost:5678

# ============================================
# FILE STORAGE
# ============================================
# Local storage path
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# AWS S3 (optional - for production)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=marketmaster-media

# Cloudinary (alternative)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# EMAIL CONFIGURATION
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@marketmaster.ai

# SendGrid (alternative)
SENDGRID_API_KEY=your_sendgrid_api_key

# ============================================
# NOTIFICATION SERVICES
# ============================================
# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Twilio (for SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# MONITORING & ANALYTICS
# ============================================
# Sentry (error tracking)
SENTRY_DSN=your_sentry_dsn

# Google Analytics
GA_TRACKING_ID=UA-XXXXXXXXX-X

# Mixpanel
MIXPANEL_TOKEN=your_mixpanel_token

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ============================================
# CRON JOBS
# ============================================
ENABLE_CRON_JOBS=true
TREND_ANALYSIS_CRON=0 2 * * *
ENGAGEMENT_TRACKING_CRON=0 */4 * * *
STOCK_ALERT_CRON=0 */6 * * *

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_AI_TAG_SCAN=true
ENABLE_IBM_BOB=true
ENABLE_TREND_ANALYTICS=true
ENABLE_AUTO_POSTING=true
ENABLE_HUMAN_APPROVAL=true

# ============================================
# SECURITY
# ============================================
BCRYPT_ROUNDS=10
SESSION_SECRET=your_session_secret
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ============================================
# API VERSIONING
# ============================================
API_VERSION=v1
API_PREFIX=/api

# ============================================
# DEVELOPMENT TOOLS
# ============================================
ENABLE_API_DOCS=true
ENABLE_GRAPHQL_PLAYGROUND=true
ENABLE_DEBUG_LOGGING=true